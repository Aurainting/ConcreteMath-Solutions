*.synctex.gz

# PDF and other outputs (optional, uncomment if you don't want to track them)
/*.pdf
*.dvi
*.ps

# Backup files created by editors
*~
*.bak
*.backup
*.swp
*.swo

# MacOS specific files
.DS_Store

# Windows specific files
Thumbs.db

# VSCode
.vscode/*
!.vscode/settings.json
