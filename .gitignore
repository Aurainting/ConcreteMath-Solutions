# Build directories
build/*
!build/.gitkeep

# LaTeX intermediate files
*.aux
*.bbl
*.blg
*.brf
*.bcf
*.fls
*.fdb_latexmk
*.log
*.out
*.toc
*.lof
*.lot
*.fmt
*.fot
*.cb
*.cb2
*.nav
*.snm
*.vrb
